{
  "name": "@enreign/productboard-mcp",
  "version": "0.3.0",
  "description": "MCP server for Productboard API integration",
  "main": "dist/index.js",
  "bin": "./productboard-mcp.js",
  "files": [
    "productboard-mcp.js",
    "dist",
    "config",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/fix-imports.js && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "TEST_TYPE=e2e jest --config jest.config.e2e.js --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "productboard",
    "api",
    "typescript",
    "model-context-protocol",
    "ai-assistant",
    "integration"
  ],
  "author": "Stanislav Shymanskyi <taysic@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enreign/productboard-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Enreign/productboard-mcp/issues"
  },
  "homepage": "https://github.com/Enreign/productboard-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "1.18.1",
    "dotenv": "^17.4.2",
    "jsonschema": "^1.4.1",
    "lru-cache": "^11.5.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "ajv": ">=6.14.0",
    "minimatch": ">=9.0.7",
    "js-yaml": ">=4.1.1",
    "form-data": ">=4.0.4",
    "hono": ">=4.12.4",
    "@hono/node-server": ">=1.19.10",
    "express-rate-limit": ">=8.2.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.1.0",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "nock": "^14.0.15",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
